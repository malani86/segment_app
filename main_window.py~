        form.addRow("Folder", self._build_path_row(self.folder_edit, self.open_folder_btn))
        form.addRow("Checkpoint", self._build_path_row(self.ckpt_edit, self.browse_ckpt_btn))
        form.addRow("Output directory", self._build_path_row(self.out_dir_edit, self.browse_out_btn))
        form.addRow("Batch size", self.batch_spin)
        form.addRow("Probability threshold", self.threshold_spin)
        form.addRow("Minimum area", self.min_area_spin)
